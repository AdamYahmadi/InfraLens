# ==========================================
# INFRALENS BACKEND CONFIGURATION
# ==========================================

# --- Proxmox API Connection ---
PVE_HOST="192.168.1.100"
PVE_PORT="8006"
PVE_USER="user@pam"
PVE_TOKEN_NAME="api-key"
PVE_TOKEN_VALUE="xxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
PVE_VERIFY_SSL="False"

# --- SSH Credentials (for probing containers) ---
PVE_SSH_USER="root"
PVE_SSH_PASSWORD="your_secure_password"

# --- App Settings ---
API_PORT="8000"

# --- AI Configuration ---
# Your local Ollama instance (Llama 3)
OLLAMA_URL="http://127.0.0.1:11434"
# Optional: OpenAI Key (if future integrations require it)
OPENAI_API_KEY="sk-your-openai-api-key-here"
